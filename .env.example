# Copy this file to ".env" and fill in your key. The agent loads .env automatically.
# The .env file is gitignored — your real key will NOT be committed.

# --- LLM brain (enables the reasoning agent) ---
# Get a free key at https://aistudio.google.com  (Gemini)
LLM_API_KEY=your-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash

# To use the hackathon's free Qwen instead, comment the two lines above and use:
# LLM_BASE_URL=https://hackathon.bitgetops.com/v1
# LLM_MODEL=qwen3.6-plus

# --- Loop pacing (keeps you under free-tier rate limits) ---
TICK_SECONDS=120

# --- Assets rotated one per tick ---
# Multiple assets stop the "real driver" finding from being a
# single-asset tautology (e.g. BTC predicting BTC).
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# --- Round-trip trading friction (fee + slippage) in basis points ---
# Charged to every closed position so paper PnL stays honest. 0 to disable.
FRICTION_BPS=6

# --- GitHub log persistence (optional, for cloud deployments) ---
# A classic PAT with "repo" scope. Pushes are floored at a 60-min interval
# so they never flood a connected deploy host's daily quota.
# GITHUB_TOKEN=your-classic-pat
# GITHUB_REPO=IamHarrie-Labs/glass-box
# GITHUB_BRANCH=master
# PUSH_INTERVAL_MINUTES=60
